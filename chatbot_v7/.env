# Copiaza in .env si completeaza valorile
# cp .env.example .env

# -- OBLIGATORIU --------------------------------------------------------------
SECRET_KEY=123456789101112131415161718192021
# -- Optional -----------------------------------------------------------------
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/chatbot
TOKEN_EXPIRE_SECONDS=3600
RATE_LIMIT_CHAT=30
RATE_LIMIT_AUTH=10
MAX_MESSAGE_LENGTH=2000
MAX_FILE_SIZE_MB=5
ALLOWED_ORIGINS=*
